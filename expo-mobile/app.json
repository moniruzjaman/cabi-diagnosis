{
  "expo": {
    "name": "উদ্ভিদ গোয়েন্দা",
    "slug": "cabi-plant-detective",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#006028"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "gov.dae.cabi.plantdetective",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "এই অ্যাপটি ফসলের পাতার ছবি তুলে রোগ নির্ণয় করতে ক্যামেরা ব্যবহার করে।",
        "NSPhotoLibraryUsageDescription": "এই অ্যাপটি গ্যালারি থেকে ফসলের ছবি নির্বাচন করতে আপনার ফটো লাইব্রেরি ব্যবহার করে।"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#006028"
      },
      "package": "gov.dae.cabi.plantdetective",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "RECORD_AUDIO"
      ],
      "config": {
        "googleMobileAdsAppId": ""
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#006028",
          "image": "./assets/splash.png",
          "imageWidth": 300,
          "dark": {
            "backgroundColor": "#004a1e"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "এই অ্যাপটি ফসলের পাতার ছবি তুলে রোগ নির্ণয় করতে ক্যামেরা ব্যবহার করে।"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "এই অ্যাপটি গ্যালারি থেকে ফসলের ছবি নির্বাচন করতে আপনার ফটো লাইব্রেরি ব্যবহার করে।"
        }
      ],
      "expo-sharing",
      "expo-status-bar"
    ],
    "extra": {
      " eas": {
        "projectId": ""
      }
    },
    "scheme": "cabiplantdetective",
    "description": "CABI Plantwise প্রোটোকল দিয়ে ফসলের রোগ নির্ণয় করুন — বাংলাদেশের কৃষকদের জন্য AI-চালিত স্মার্ট কৃষি অ্যাপ",
    "category": "education",
    "lang": "bn"
  }
}
