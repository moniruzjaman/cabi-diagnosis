# ─────────────────────────────────────────────────────────────
# উদ্ভিদ গোয়েন্দা (Plant Detective) — Environment Variables
# ─────────────────────────────────────────────────────────────
# Set these in Vercel Dashboard → Settings → Environment Variables.
# NEVER commit .env files to version control.
#
# NOTE: No VITE_ prefixed vars are needed. All sensitive operations
# are handled server-side via API routes. The frontend never sees
# any API keys or database credentials.

# ═══ AI Provider Keys (at least one required for diagnosis) ═══

# Google Gemini API Key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq API Key — https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter API Key — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ═══ Supabase Configuration (optional — enables persistent analytics) ═══

# Supabase project URL
SUPABASE_URL=

# Supabase anon/public key (used server-side only, never exposed to frontend)
SUPABASE_PUBLISHABLE_KEY=

# Supabase service role key (admin access — optional, for server-side only)
# SUPABASE_SERVICE_ROLE_KEY=

# ═══ Security Configuration ═══

# Request signing: AUTO-CONFIGURED — no manual setup needed.
# The signing secret is automatically derived from your Supabase credentials
# (or AI API keys as fallback). No separate signing key required.

# Admin access to /api/test: AUTO-CONFIGURED — no manual setup needed.
# The admin secret is auto-derived from your Supabase credentials.
# Access via the app (signed request) or ?admin=YOUR_AUTO_DERIVED_KEY.
# The 403 response includes a hint to help you find your key.

# ═══ CORS Configuration (optional) ═══

# Comma-separated list of allowed origins for API CORS.
# Only used in production (VERCEL env set).
# Defaults to https://cabi-diagnosis.vercel.app if not set.
# ALLOWED_ORIGINS=https://cabi-diagnosis.vercel.app,https://your-custom-domain.com

# ═══ Vercel (auto-set by Vercel deployment) ═══
# VERCEL=1
